# Copy this to .env and fill in the values

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-something-random

# SQLite path (default works for local dev, Docker uses /app/data/data.db)
# DB_PATH=./backend/data.db

# Anthropic API for CV copywriting
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_TIMEOUT_SECONDS=45
